# Copy to .env and fill in. Used by set-webhook.mjs (run: node --env-file=.env set-webhook.mjs)
# The same values must also be set in the Vercel project's Environment Variables.

TELEGRAM_BOT_TOKEN=your-botfather-token
WEBHOOK_URL=https://<your-project>.vercel.app/api/telegram
# Only A-Z a-z 0-9 _ - allowed (no @, no spaces). Must match Vercel's TELEGRAM_WEBHOOK_SECRET.
TELEGRAM_WEBHOOK_SECRET=some_random_string
